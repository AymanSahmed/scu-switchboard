              "triggers": {
                "HTTP_Webhook": {
                  "type": "Request",
                  "kind": "Http",
                  "inputs": {
                    "schema": {
                      "type": "object",
                      "required": [
                        "action",
                        "user"
                      ],
                      "properties": {
                        "action": {
                          "type": "string",
                          "description": "One of: start, scale, stop, status"
