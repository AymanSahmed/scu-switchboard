                            "correlationId": "@workflow()['run']['name']",
                            "timestamp": "@utcNow()"
                          }
                        },
                        "Return_Success": {
                          "type": "Response",
                          "runAfter": {
                            "Compose_Success_Response": [
                              "Succeeded"
                            ]
                          },
                          "inputs": {
                            "statusCode": 200,
                            "headers": {
                              "Content-Type": "application/json"
                            },
                            "body": "@outputs('Compose_Success_Response')"
                          }
                        },
                        "Return_ARM_Error": {
                          "type": "Response",
                          "runAfter": {
                            "Switch_On_Action": [
                              "Failed",
                              "TimedOut"
                            ]
                          },
                          "inputs": {
                            "statusCode": 502,
                            "headers": {
                              "Content-Type": "application/json"
                            },
                            "body": {
                              "error": "arm_error",
                              "message": "ARM operation failed. Check Logic App run history for details.",
                              "correlationId": "@workflow()['run']['name']"
                            }
                          }
                        }
                      },
                      "else": {
                        "actions": {
                          "Return_User_Not_Found": {
                            "type": "Response",
                            "inputs": {
