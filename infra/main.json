                      "type": "Http",
                      "runAfter": {
                        "Resolve_User_Alias": [
                          "Succeeded"
                        ]
                      },
                      "inputs": {
                        "method": "GET",
                        "uri": "@{concat(parameters('appConfigEndpoint'), '/kv/scu%3Aenv%3A', outputs('Resolve_User_Alias'), '?api-version=2023-11-01')}",
                        "authentication": {
                          "type": "ManagedServiceIdentity",
                          "audience": "https://azconfig.io"
                        }
                      }
                    },
                    "Check_User_Found": {
                      "type": "If",
                      "runAfter": {
                        "Get_User_Config": [
                          "Succeeded",
                          "Failed"
                        ]
                      },
                      "expression": {
                        "and": [
                          {
                            "equals": [
                              "@outputs('Get_User_Config')['statusCode']",
                              200
                            ]
                          }
                        ]
                      },
                      "actions": {
                        "Parse_User_Config": {
                          "type": "Compose",
                          "inputs": "@json(body('Get_User_Config')['value'])"
                        },
                        "Switch_On_Action": {
                          "type": "Switch",
                          "runAfter": {
                            "Parse_User_Config": [
                              "Succeeded"
                            ]
                          },
                          "expression": "@triggerBody()?['action']",
