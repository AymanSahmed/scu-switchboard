                                    "body": {
                                      "location": "@outputs('Parse_User_Config')['region']",
                                      "properties": {
                                        "numberOfUnits": "@coalesce(triggerBody()?['scuCount'], outputs('Parse_User_Config')['defaultScuCount'])",
                                        "crossGeoCompute": "Allowed",
                                        "geo": "@outputs('Parse_User_Config')['geoCode']"
                                      }
                                    },
                                    "authentication": {
                                      "type": "ManagedServiceIdentity",
                                      "audience": "https://management.azure.com/"
                                    }
                                  }
                                }
                              }
                            },
                            "scale": {
                              "case": "scale",
                              "actions": {
                                "Scale_Capacity": {
                                  "type": "Http",
                                  "inputs": {
                                    "method": "PUT",
                                    "uri": "@{concat('https://management.azure.com/subscriptions/', outputs('Parse_User_Config')['subscriptionId'], '/resourceGroups/', outputs('Parse_User_Config')['resourceGroup'], '/providers/Microsoft.SecurityCopilot/capacities/', outputs('Parse_User_Config')['capacityName'], '?api-version=2024-03-01-preview')}",
                                    "body": {
                                      "location": "@outputs('Parse_User_Config')['region']",
                                      "properties": {
                                        "numberOfUnits": "@triggerBody()?['scuCount']",
                                        "crossGeoCompute": "Allowed",
                                        "geo": "@outputs('Parse_User_Config')['geoCode']"
                                      }
                                    },
                                    "authentication": {
                                      "type": "ManagedServiceIdentity",
                                      "audience": "https://management.azure.com/"
                                    }
                                  }
                                }
                              }
                            },
                            "stop": {
                              "case": "stop",
                              "actions": {
                                "Stop_Capacity": {
                                  "type": "Http",
                                  "inputs": {
                                    "method": "DELETE",
                                    "uri": "@{concat('https://management.azure.com/subscriptions/', outputs('Parse_User_Config')['subscriptionId'], '/resourceGroups/', outputs('Parse_User_Config')['resourceGroup'], '/providers/Microsoft.SecurityCopilot/capacities/', outputs('Parse_User_Config')['capacityName'], '?api-version=2024-03-01-preview')}",
                                    "authentication": {
                                      "type": "ManagedServiceIdentity",
                                      "audience": "https://management.azure.com/"
                                    }
                                  }
                                }
                              }
                            },
                            "status": {
                              "case": "status",
                              "actions": {
                                "Get_Capacity_Status": {
                                  "type": "Http",
                                  "inputs": {
                                    "method": "GET",
                                    "uri": "@{concat('https://management.azure.com/subscriptions/', outputs('Parse_User_Config')['subscriptionId'], '/resourceGroups/', outputs('Parse_User_Config')['resourceGroup'], '/providers/Microsoft.SecurityCopilot/capacities/', outputs('Parse_User_Config')['capacityName'], '?api-version=2024-03-01-preview')}",
                                    "authentication": {
                                      "type": "ManagedServiceIdentity",
                                      "audience": "https://management.azure.com/"
                                    }
                                  }
                                }
                              }
                            }
                          },
                          "default": {
                            "actions": {
                              "Return_Invalid_Action": {
                                "type": "Response",
                                "inputs": {
                                  "statusCode": 400,
                                  "headers": {
                                    "Content-Type": "application/json"
                                  },
                                  "body": {
                                    "error": "invalid_action",
                                    "message": "Valid actions: start, scale, stop, status"
                                  }
                                }
                              }
                            }
                          }
                        },
                        "Compose_Success_Response": {
                          "type": "Compose",
                          "runAfter": {
                            "Switch_On_Action": [
                              "Succeeded"
                            ]
                          },
                          "inputs": {
                            "status": "success",
                            "action": "@triggerBody()?['action']",
