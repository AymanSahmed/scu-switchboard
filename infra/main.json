                  }
                }
              },
              "actions": {
                "Validate_Secret": {
                  "type": "If",
                  "expression": {
                    "and": [
                      {
                        "equals": [
                          "@{triggerOutputs()['headers']['x-webhook-secret']}",
                          "@{parameters('webhookSecret')}"
                        ]
                      }
                    ]
                  },
                  "actions": {
                    "Resolve_User_Alias": {
                      "type": "Compose",
                      "inputs": "@{toLower(first(split(triggerBody()?['user'], '@')))}"
